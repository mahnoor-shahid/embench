# ============================================
# embench — API keys for embedding backends
# ============================================
# Copy this file to .env and fill in the keys for the providers you use:
#   cp .env.example .env
#
# .env is git-ignored and must never be committed. This .env.example is safe
# to commit. You only need keys for the backends you actually benchmark —
# the local SentenceTransformerModel and the DummyModel need none.

# --- OpenAI -------------------------------------------------
# Used by eb.OpenAIModel(...)
OPENAI_API_KEY=your_openai_api_key_here
# Optional: override the endpoint (Azure / proxy / self-hosted)
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Cohere -------------------------------------------------
# Used by eb.CohereModel(...)
COHERE_API_KEY=your_cohere_api_key_here

# --- Voyage AI ----------------------------------------------
# Used by eb.VoyageModel(...)
VOYAGE_API_KEY=your_voyage_api_key_here

# --- Google (Gemini embeddings) -----------------------------
# For a planned GoogleModel adapter (not yet implemented).
GOOGLE_API_KEY=your_google_api_key_here

# --- Hugging Face -------------------------------------------
# Needed only for gated models or the HF Inference API.
# Local models via sentence-transformers need no key.
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
